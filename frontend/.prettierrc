{
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 4,
    "useTabs": false,
    "arrowParens": "always",
    "bracketSameLine": true,
    "overrides": [
        {
            "files": ["*.html", "**/*.html"],
            "options": {
                "printWidth": 200,
                "singleAttributePerLine": false,
                "bracketSameLine": true
            }
        }
    ]
}
